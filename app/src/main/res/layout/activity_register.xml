<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastro"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/textViewNomeRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insira seu nome"
            android:textColor="#666666"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textErrorNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="O nome é obrigatório"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editNomeRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:ems="10"
            android:textColor="@color/black"
            android:inputType="textPersonName"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/textViewEmailRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insira seu email"
            android:textColor="#666666"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textErrorEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="Deve ser um email válido"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editEmailRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:ems="10"
            android:textColor="@color/black"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/textViewSenhaRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insira sua senha"
            android:textColor="#666666"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textErrorSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="A senha deve conter no mínimo 6 caracteres"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editSenhaRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:ems="10"
            android:textColor="@color/black"
            android:inputType="textPassword"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dados da Empresa"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/textViewNomeEmpresaRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insira o nome da empresa"
            android:textColor="#666666"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textErrorNomeEmpresa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="Nome da empresa é obrigatório"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editNomeEmpresa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:ems="10"
            android:textColor="@color/black"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/textViewCnpjEmpresa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insira o CNPJ"
            android:textColor="#666666"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textErrorCnpj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="CNPJ é obrigatório"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editCnpjEmpresa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:ems="10"
            android:textColor="@color/black"
            android:inputType="number"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/buttonRegistrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Registrar"
            android:onClick="register"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>